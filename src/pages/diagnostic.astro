---
import Base from "@/layouts/Base.astro";
import DynamicIcon from "@/helpers/DynamicIcon.astro";
---

<Base
  title="Diagnostic gratuit de votre site – Performance, sécurité, obsolescence"
  metaTitle="Diagnostic gratuit – Performance, sécurité, obsolescence – Backstage"
  metaDescription="Audit gratuit en 30 minutes : score Lighthouse, grade de sécurité, détection de logiciels obsolètes. Rapport envoyé par email."
  headerLayout="two"
  headerPosition="fixed"
>
  {/* Hero */}
  <section class="relative overflow-hidden bg-white py-20 md:py-28">
    <div class="container">
      <div class="mx-auto text-center">
        <span class="bg-accent/10 text-accent mb-4 inline-block rounded-full px-4 py-1 text-sm font-medium">
          Diagnostic gratuit
        </span>
        <h1 class="text-dark text-h1-sm md:text-h1 leading-tight">
          Votre site a peut-être un problème que vous ne voyez pas.
        </h1>
        <p class="text-text-default mx-auto mt-6 text-lg leading-relaxed">
          Un diagnostic gratuit révèle en quelques minutes l'état réel de votre site :
          performances, sécurité, obsolescence. Vous recevez le rapport complet par email.
        </p>
      </div>
    </div>
  </section>

  {/* Ce que le diagnostic révèle */}
  <section class="section-spacing-vertical bg-theme-light">
    <div class="container">
      <div class="mx-auto mb-12 text-center">
        <h2 class="text-h2-sm md:text-h2">Ce que le diagnostic révèle</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-2xl border border-border-light bg-white p-8 drop-shadow-xl drop-shadow-transparent">
          <div class="bg-primary/10 mb-6 flex size-18 items-center justify-center rounded-2xl">
            <DynamicIcon name="gauge" class="text-primary size-9" />
          </div>
          <h3 class="text-h3-sm mb-4 s:text-h3">Performance Lighthouse</h3>
          <p class="text-text-default leading-relaxed">
            Score de 0 à 100 sur mobile. En dessous de 50, bon nombre de visiteurs quitte la
            page avant d'avoir vu le contenu.
          </p>
        </div>

        <div class="rounded-2xl border border-border-light bg-white p-8 drop-shadow-xl drop-shadow-transparent">
          <div class="bg-primary/10 mb-6 flex size-18 items-center justify-center rounded-2xl">
            <DynamicIcon name="shield-check" class="text-primary size-9" />
          </div>
          <h3 class="text-h3-sm mb-4 md:text-h3">Grade de sécurité</h3>
          <p class="text-text-default leading-relaxed">
            De A+ à F, vérifiable publiquement en quelques secondes. Un grade entre B et F
            indique des headers de sécurité manquants, corrigeables en 30 minutes.
          </p>
        </div>

        <div class="rounded-2xl border border-border-light bg-white p-8 drop-shadow-xl drop-shadow-transparent">
          <div class="bg-primary/10 mb-6 flex size-18 items-center justify-center rounded-2xl">
            <DynamicIcon name="recycle" class="text-primary size-9" />
          </div>
          <h3 class="text-h3-sm mb-4 md:text-h3">Logiciels obsolètes</h3>
          <p class="text-text-default leading-relaxed">
            Les dernières versions de PHP et de WordPress reçoivent régulièrement des correctifs
            de sécurité. Les précédentes ne sont plus maintenues et présentent un risque majeur
            pour la sécurité de votre site.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Exemple réel */}
  <section class="section-spacing-vertical bg-white">
    <div class="container">
      <div class="mx-auto text-center">
        <span class="bg-accent/10 text-accent mb-4 inline-block rounded-full px-4 py-1 text-sm font-medium">
          Exemple réel
        </span>
        <h2 class="text-h2-sm md:text-h2 mt-4">La preuve par l'exemple</h2>
        <p class="text-text-default mt-6 text-lg leading-relaxed">
          Voici le diagnostic de ce site – backstage.click – tel qu'il sort de l'outil.
        </p>
      </div>

      <div class="mt-12 grid gap-8 md:grid-cols-2">
        <div>
          <h3 class="text-lg font-semibold">Métriques Pagespeed</h3>
          <div class="mt-6 space-y-4">
            <div class="flex items-center justify-between rounded-xl border border-border-light bg-white px-4 py-3">
              <span class="font-medium">Performance</span>
              <div class="flex items-center gap-3">
                <span class="text-lg font-bold">100/100</span>
                <span class="text-green-600">✓</span>
              </div>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border-light bg-white px-4 py-3">
              <span class="font-medium">Accessibilité</span>
              <div class="flex items-center gap-3">
                <span class="text-lg font-bold">100/100</span>
                <span class="text-green-600">✓</span>
              </div>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border-light bg-white px-4 py-3">
              <span class="font-medium">Bonnes pratiques</span>
              <div class="flex items-center gap-3">
                <span class="text-lg font-bold">100/100</span>
                <span class="text-green-600">✓</span>
              </div>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border-light bg-white px-4 py-3">
              <span class="font-medium">SEO</span>
              <div class="flex items-center gap-3">
                <span class="text-lg font-bold">100/100</span>
                <span class="text-green-600">✓</span>
              </div>
            </div>
          </div>
        </div>

        <div>
          <h3 class="text-lg font-semibold">Autres métriques & Stack technique</h3>
          <div class="mt-6 space-y-4">
            <div class="flex items-center justify-between rounded-xl border border-border-light bg-white px-4 py-3">
              <span class="font-medium">Sécurité</span>
              <div class="flex items-center gap-3">
                <span class="text-sm font-medium">A+</span>
                <span class="text-green-600">✓</span>
              </div>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border-light bg-white px-4 py-3">
              <span class="font-medium">Navigation agentique</span>
              <div class="flex items-center gap-3">
                <span class="text-sm font-medium">2/2</span>
                <span class="text-green-600">✓</span>
              </div>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border-light bg-white px-4 py-3">
              <span class="font-medium">Astro</span>
              <div class="flex items-center gap-3">
                <span class="text-sm font-medium">statique</span>
                <span class="text-green-600">✓</span>
              </div>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border-light bg-white px-4 py-3">
              <span class="font-medium">Serveur</span>
              <div class="flex items-center gap-3">
                <span class="text-sm font-medium">Hébergement statique</span>
                <span class="text-green-600">✓</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Formulaire */}
  <section class="section-spacing-vertical bg-theme-light">
    <div class="container">
      <div class="mx-auto">
        <div class="text-center">
          <h2 class="text-h2-sm md:text-h2">Demandez votre diagnostic gratuit</h2>
          <p class="text-text-default mt-6 text-lg leading-relaxed">
            Indiquez l'URL de votre site et votre email. Le rapport vous est envoyé sous 10
            minutes.
          </p>
        </div>

        <form id="diag-form" action="/api/scan_request.php" method="POST" class="mt-12 space-y-4">
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label for="diag-url" class="text-dark mb-1 block text-sm font-medium">URL de votre site *</label>
              <input
                id="diag-url"
                name="url_site"
                type="url"
                required
                placeholder="https://votre-site.fr"
                class="border-border-light bg-body focus:border-accent w-full rounded-lg border px-4 py-2.5 outline-none transition-colors"
              />
            </div>
            <div>
              <label for="diag-email" class="text-dark mb-1 block text-sm font-medium">Votre email *</label>
              <input
                id="diag-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                class="border-border-light bg-body focus:border-accent w-full rounded-lg border px-4 py-2.5 outline-none transition-colors"
              />
            </div>
          </div>

          <div>
            <label for="diag-message" class="text-dark mb-1 block text-sm font-medium">Message (optionnel)</label>
            <textarea
              id="diag-message"
              name="message"
              rows={3}
              placeholder="Une question particulière ?"
              class="border-border-light bg-body focus:border-accent w-full rounded-lg border px-4 py-2.5 outline-none transition-colors"
            ></textarea>
          </div>

          <div style="position:absolute;left:-9999px" aria-hidden="true">
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <input type="hidden" id="diag-source" name="source" value="" />

          <div id="diag-error" class="hidden text-sm text-red-600"></div>

          <button type="submit" id="diag-submit" class="text-flip-hover-anim magnetic-hover-anim btn btn-primary w-full justify-center rounded-md px-7 py-4.5 text-base leading-6 font-semibold normal-case">
            <span class="btn-text text-flip-inner" data-content="Recevoir mon diagnostic →">Recevoir mon diagnostic →</span>
          </button>

          <p class="text-text-default text-center text-sm">
            En soumettant ce formulaire, vous acceptez notre
            <a href="/politique-confidentialite/" class="underline hover:no-underline">politique de confidentialité</a>.
          </p>
        </form>

        <div id="diag-success" class="hidden text-center text-sm text-green-600">
          Votre demande a bien été enregistrée. Le rapport arrive sous 10 minutes.
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    function trackDiagnosticVisit() {
      const params = new URLSearchParams(window.location.search);
      const site = params.get('site') || '';
      const mail = params.get('mail') || '';
      const source = params.get('source') || '';
      if (site || mail) {
        const trackingUrl = new URL('https://backstage.click/api/diagnostic-visit.php');
        trackingUrl.searchParams.set('site', site);
        trackingUrl.searchParams.set('mail', mail);
        trackingUrl.searchParams.set('source', source);
        fetch(trackingUrl.toString()).catch(() => {});
      }
    }

    function initDiagnosticForm() {
      const form = document.getElementById('diag-form');
      const button = document.getElementById('diag-submit');
      const success = document.getElementById('diag-success');
      const error = document.getElementById('diag-error');
      if (!form || !button || !success || !error) return;
      if (form.dataset.formInit) return;
      form.dataset.formInit = 'true';

      const params = new URLSearchParams(window.location.search);
      const siteParam = params.get('site');
      const mailParam = params.get('mail');
      const sourceParam = params.get('source');

      if (siteParam) {
        const urlInput = document.getElementById('diag-url');
        if (urlInput) urlInput.value = siteParam;
      }
      if (mailParam) {
        const emailInput = document.getElementById('diag-email');
        if (emailInput) emailInput.value = mailParam;
      }
      if (sourceParam) {
        const sourceInput = document.getElementById('diag-source');
        if (sourceInput) sourceInput.value = sourceParam;
      }

      const defaultLabel = 'Recevoir mon diagnostic →';
      const defaultSuccessMessage = 'Votre demande a bien été enregistrée. Le rapport arrive sous 10 minutes.';

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        button.disabled = true;
        button.querySelector('.btn-text').textContent = 'Envoi...';
        error.classList.add('hidden');
        success.classList.add('hidden');

        try {
          const formData = new FormData(form);
          const payload = {
            url_site: String(formData.get('url_site') ?? ''),
            email: String(formData.get('email') ?? ''),
            message: String(formData.get('message') ?? ''),
            website: String(formData.get('website') ?? ''),
            source: String(formData.get('source') ?? params.get('source') ?? ''),
          };

          const response = await fetch('/api/scan_request.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          const data = await response.json();

          if (response.ok && data.success) {
            success.textContent = typeof data.message === 'string' && data.message !== '' ? data.message : defaultSuccessMessage;
            form.classList.add('hidden');
            success.classList.remove('hidden');
            form.reset();
            return;
          }

          error.textContent = typeof data.message === 'string' && data.message !== '' ? data.message : 'Une erreur est survenue.';
          error.classList.remove('hidden');
        } catch {
          error.textContent = 'Une erreur est survenue.';
          error.classList.remove('hidden');
        } finally {
          button.disabled = false;
          button.querySelector('.btn-text').textContent = defaultLabel;
        }
      });
    }

    trackDiagnosticVisit();
    initDiagnosticForm();
    document.addEventListener('astro:after-swap', () => {
      trackDiagnosticVisit();
      initDiagnosticForm();
    });
  </script>
</Base>
