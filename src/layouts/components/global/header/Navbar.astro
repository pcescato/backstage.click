---
import NavMenuItem from "@/layouts/components/global/header/MenuItem.astro";
import { useTranslations } from "@/lib/utils/i18nUtils.ts";
import { getHeaderMenu } from "@/lib/utils/menu";

interface Props {
  isMobile?: boolean;
  [key: string]: any;
}

import config from ".astro/config.generated.json";
const t = await useTranslations(Astro.currentLocale as string);
const main = getHeaderMenu(t);

const {
  isMobile,
  class: ClassName,
} = Astro.props;
---

<ul
  id="nav-menu"
  class:list={["navbar", isMobile && "navbar-mobile", ClassName]}
  role="menu">
  {main.map((menu) => <NavMenuItem isMobile={isMobile} menu={menu} />)}
</ul>
