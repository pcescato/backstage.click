---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import { footerNavItems, legalLinks } from '@/config/nav.config';

const comparisonCards = [
  {
    title: 'SaaS classique',
    className: 'bg-background-secondary',
    iconPath:
      'M3 6.75A2.75 2.75 0 0 1 5.75 4h12.5A2.75 2.75 0 0 1 21 6.75v10.5A2.75 2.75 0 0 1 18.25 20H5.75A2.75 2.75 0 0 1 3 17.25V6.75Zm2.75-.75a.75.75 0 0 0-.75.75v10.5c0 .414.336.75.75.75h12.5a.75.75 0 0 0 .75-.75V6.75a.75.75 0 0 0-.75-.75H5.75ZM7 8h10v2H7V8Zm0 4h10v2H7v-2Zm0 4h7v2H7v-2Z',
    items: [
      '~250 € / mois = 3 000 € / an',
      'Données hébergées chez l’éditeur',
      'Abonnement sans fin',
      'RGPD : sous-traitant obligatoire',
      'Résiliation = perte d’accès immédiate',
    ],
  },
  {
    title: 'GCF Pro',
    className: 'bg-brand-500/10 border-brand-500/30',
    iconPath:
      'M4 22V4l2-2 2 2 2-2 2 2 2-2 2 2 2-2 2 2v18l-2-2-2 2-2-2-2 2-2-2-2 2-2-2Zm2-2.1.7-.7.7.7.7-.7.7.7.7-.7.7.7.7-.7.7.7.7-.7.7.7V4.45l-.7.7-.7-.7-.7.7-.7-.7-.7.7-.7-.7-.7.7-.7-.7V19.9ZM7 14v-2h10v2Zm0 4v-2h7v2Zm0-6v-2h10v2Z',
    items: [
      '3 900 € HT — une seule fois',
      'Hébergé sur votre propre serveur',
      'Amorti en 23 mois, économies ensuite',
      'Souveraineté des données native',
      'Vous restez propriétaire, pour toujours',
    ],
  },
] as const;

const features = [
  {
    title: 'Qualiopi natif',
    description: 'Indicateurs automatisés, BPF export XLSX, module réclamations avec calcul délai 30 jours.',
    iconName: 'verified',
  },
  {
    title: 'Facturation complète',
    description:
      'Proformas, factures, avoirs, acomptes. Connecteurs VosFactures et Sellsy. Échéance septembre 2026 : facturation électronique intégrée.',
    iconName: 'fact_check',
  },
  {
    title: 'Portails stagiaires',
    description:
      'Convocations automatiques, émargements électroniques, accès OTP passwordless pour stagiaires et entreprises.',
    iconName: 'co_present',
  },
  {
    title: 'IA intégrée',
    description:
      'Génération de contenu catalogue depuis PDF (GPT-4o ou Ollama local). Réduction de 70% du temps de création catalogue.',
    iconName: 'auto_awesome',
  },
] as const;
---

<BaseLayout
  title="GCF Pro"
  description="GCF Pro : logiciel de gestion on-premise à licence perpétuelle pour organismes de formation."
>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=auto_awesome,co_present,fact_check,verified');

    .gcf-pro-material-symbol {
      font-family: 'Material Symbols Outlined';
      font-weight: 400;
      font-style: normal;
      font-size: 32px;
      line-height: 1;
      display: inline-block;
      letter-spacing: normal;
      text-transform: none;
      white-space: nowrap;
      word-wrap: normal;
      direction: ltr;
      -webkit-font-smoothing: antialiased;
      font-variation-settings:
        'FILL' 0,
        'wght' 400,
        'GRAD' 0,
        'opsz' 48;
    }
  </style>

  <Header slot="header" position="fixed" size="lg" showActiveState showCta={false} actions={[]} />

  <div class="min-h-screen pt-16">
    <Hero
      layout="centered"
      size="lg"
      showGrid
      class="border-border border-b pt-12 pb-16 md:pt-20 md:pb-20"
    >
      <Badge slot="badge" variant="brand" pill class="px-3 py-1 text-sm">Logiciel de gestion</Badge>

      <h1 slot="title" class="max-w-4xl !leading-[1.05] !text-4xl md:!text-5xl lg:!text-6xl">
        Fini les abonnements SaaS.
        <br />
        GCF Pro installé chez vous, pour toujours.
      </h1>

      <p slot="description" class="max-w-3xl">
        Solution on-premise à licence perpétuelle. Vos données restent sur votre serveur. Vous
        payez une seule fois.
      </p>
    </Hero>

    <section class="border-border bg-background border-b py-20">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
            Comparatif
          </h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          {
            comparisonCards.map((card) => (
              <Card
                variant="elevated"
                padding="lg"
                class={`border-border h-full border ${card.className}`}
              >
                <div class="flex h-full flex-col gap-5">
                  <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="h-12 w-12 shrink-0"
                      aria-hidden="true"
                    >
                      <path d={card.iconPath}></path>
                    </svg>
                  </div>

                  <div class="space-y-3">
                    <h3 class="font-display text-foreground text-2xl font-bold">{card.title}</h3>
                    <ul class="text-foreground-muted space-y-2 leading-relaxed">
                      {card.items.map((item) => <li>• {item}</li>)}
                    </ul>
                  </div>
                </div>
              </Card>
            ))
          }
        </div>

        <p class="text-foreground-muted mt-8 text-center">
          Économies projetées après amortissement : 2 200 € / an.
        </p>
      </div>
    </section>

    <section class="border-border bg-background-secondary border-b py-20">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
            Ce que couvre GCF Pro
          </h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          {
            features.map((feature) => (
              <Card variant="elevated" padding="lg" class="border-border h-full border">
                <div class="flex h-full flex-col gap-5">
                  <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
                    <span class="gcf-pro-material-symbol shrink-0" aria-hidden="true">
                      {feature.iconName}
                    </span>
                  </div>

                  <div class="space-y-3">
                    <h3 class="font-display text-foreground text-2xl font-bold">
                      {feature.title}
                    </h3>
                    <p class="text-foreground-muted leading-relaxed">{feature.description}</p>
                  </div>
                </div>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section class="invert-section bg-background border-t border-border py-20">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
          Prêt à reprendre le contrôle ?
        </h2>
        <p class="text-foreground-muted mt-6 text-lg leading-relaxed">
          Licence annuelle 1 490 € HT ou licence perpétuelle 3 900 € HT. La formation
          Administrateur (3h) est éligible OPCO/CPF.
        </p>
        <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
          <Button href="https://gcfpro.fr" target="_blank">
            Découvrir GCF Pro →
          </Button>
          <Button variant="outline" href="/contact">
            Demander une démo
          </Button>
        </div>
      </div>
    </section>
  </div>

  <Footer slot="footer" layout="simple" nav={footerNavItems} legalLinks={legalLinks} />
</BaseLayout>
