---
import type { HTMLAttributes } from 'astro/types';
import { cn } from '@/lib/cn';
import { getNavItems, type NavItem as NavConfigItem } from '@/config/nav.config';
import { headerVariants, headerInnerVariants } from './header.variants';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import siteConfig from '@/config/site.config';

export interface NavItem {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
}

export interface HeaderAction {
  icon: string;
  href: string;
  label: string;
  iconOnly?: boolean;
  target?: string;
}

interface Props extends HTMLAttributes<'header'> {
  layout?: 'default' | 'centered' | 'minimal';
  position?: 'fixed' | 'sticky' | 'static';
  size?: 'sm' | 'md' | 'lg';
  variant?: 'default' | 'solid' | 'transparent';
  colorScheme?: 'default' | 'invert';
  shape?: 'bar' | 'floating';
  nav?: NavItem[];
  extraNav?: NavItem[];
  showCta?: boolean;
  cta?: { label?: string; href?: string; icon?: string; trailingIcon?: string };
  actions?: HeaderAction[];
  showThemeToggle?: boolean;
  showMobileMenu?: boolean;
  showActiveState?: boolean;
  logoText?: string;
  hideLogo?: boolean;
  showLanguageSwitcher?: boolean;
  showSocialLinks?: boolean;
  showScrollProgress?: boolean;
  scrollProgressPosition?: 'top' | 'bottom';
  autoHide?: boolean;
  invertOnReturn?: boolean;
  maxWidth?: '4xl' | '5xl' | '6xl' | '7xl' | 'full';
}

const {
  layout = 'default',
  position = 'fixed',
  size = 'lg',
  variant = 'solid',
  colorScheme = 'default',
  shape = 'bar',
  nav,
  extraNav = [],
  showCta = false,
  cta = { label: 'Start a project', href: '/contact' },
  actions = [],
  showThemeToggle: _showThemeToggle = true,
  showMobileMenu = true,
  showActiveState = true,
  logoText,
  hideLogo = false,
  showLanguageSwitcher: _showLanguageSwitcher = false,
  showSocialLinks: _showSocialLinks = false,
  showScrollProgress = false,
  scrollProgressPosition = 'bottom',
  autoHide = false,
  invertOnReturn = true,
  maxWidth = '6xl',
  class: className,
  ...attrs
} = Astro.props;

const isFloating = shape === 'floating';
const isInvert = colorScheme === 'invert';
const maxWidthClass = {
  '4xl': 'max-w-4xl',
  '5xl': 'max-w-5xl',
  '6xl': 'max-w-6xl',
  '7xl': 'max-w-7xl',
  full: 'max-w-full',
}[maxWidth];

const defaultNav = getNavItems().map((item: NavConfigItem) => ({
  label: item.label,
  href: item.href,
}));
const navItems: NavItem[] = nav || [...extraNav, ...defaultNav];

const currentPath = Astro.url.pathname;
const isLandingPage = currentPath === '/';
const ctaHref = cta.href?.startsWith('#') && !isLandingPage ? `/${cta.href}` : cta.href;

const hasLogoSlot = Astro.slots.has('logo');
const hasNavSlot = Astro.slots.has('nav');
const hasActionsSlot = Astro.slots.has('actions');
const hasMobileMenuSlot = Astro.slots.has('mobile-menu');

const headerClasses = cn(
  headerVariants({ position, variant, shape }),
  isInvert && !isFloating && 'invert-section',
  className
);

const innerClasses = cn(
  headerInnerVariants({ size, shape }),
  !isFloating && maxWidthClass,
  'hdr-inner'
);

function isActive(href: string): boolean {
  if (!showActiveState) return false;
  if (href.startsWith('#')) return false;
  return currentPath === href || currentPath.startsWith(href + '/');
}

function getNavIcon(href: string): string {
  if (href.startsWith('/diagnostic')) return 'shield-check';
  if (href.startsWith('/prestations')) return 'sparkles';
  if (href.startsWith('/gcf-pro')) return 'layers';
  if (href.startsWith('/contact')) return 'mail';
  if (href.startsWith('#')) return 'hash';
  return 'chevron-right';
}

const menuId = `mobile-menu-${Math.random().toString(36).slice(2, 9)}`;
const buttonId = `${menuId}-button`;
---

<header
  class={headerClasses}
  data-menu-id={menuId}
  data-button-id={buttonId}
  data-header-shape={shape}
  data-header-variant={variant}
  data-header-color-scheme={colorScheme}
  data-header-auto-hide={autoHide ? 'true' : 'false'}
  data-header-invert-on-return={invertOnReturn ? 'true' : 'false'}
  {...attrs}
>
  <div class={innerClasses}>
    {
      !hideLogo &&
        (hasLogoSlot ? (
          <slot name="logo" />
        ) : (
          <a href="/" class="flex items-center gap-2" aria-label={logoText || siteConfig.name}>
            <img
              src="/backstage-logo.webp"
              alt="Backstage"
              width="280"
              height="33"
              class="h-8 w-auto"
              loading="eager"
              decoding="async"
            />
          </a>
        ))
    }

    <div class="flex items-center gap-2 justify-self-end lg:col-start-3">
      {
        hasActionsSlot ? (
          <slot name="actions" />
        ) : (
          <>
            {
              layout !== 'minimal' &&
                (hasNavSlot ? (
                  <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
                    <slot name="nav" />
                  </nav>
                ) : (
                  <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
                    {navItems.map(({ label, href, children }) => {
                      const hasChildren = children && children.length > 0;
                      if (hasChildren) {
                        return (
                          <div class="relative" data-nav-dropdown>
                            <button
                              type="button"
                              class={cn(
                                'nav-link nav-dropdown-trigger relative rounded-md px-3 py-2 text-sm',
                                'transition-all duration-(--transition-fast)',
                                'inline-flex items-center gap-1',
                                isFloating && 'hdr-invert-text',
                                isFloating
                                  ? isActive(href)
                                    ? 'hdr-nav-active font-semibold'
                                    : 'font-medium'
                                  : isActive(href)
                                    ? 'nav-link-active bg-secondary text-foreground font-semibold'
                                    : 'nav-link-inactive text-foreground-muted hover:bg-secondary/70 hover:text-foreground font-medium'
                              )}
                              aria-haspopup="true"
                              aria-expanded="false"
                              data-dropdown-trigger
                            >
                              {label}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-dropdown-chevron h-3 w-3 shrink-0 transition-transform duration-150" aria-hidden="true">
                                <path d="M6 9l6 6 6-6" />
                              </svg>
                            </button>
                            <div
                              class="nav-dropdown-panel"
                              role="menu"
                              aria-orientation="vertical"
                              data-dropdown-menu
                            >
                              <a
                                href={href}
                                class={cn(
                                  'flex items-center px-3 py-2 text-sm rounded-md transition-colors',
                                  'hover:bg-secondary focus:bg-secondary',
                                  'text-foreground-secondary hover:text-foreground',
                                  'focus-visible:ring-2 focus-visible:ring-ring outline-none'
                                )}
                                role="menuitem"
                                tabindex={0}
                                data-dropdown-item="0"
                              >
                                {label}
                              </a>
                              <div class="my-1.5 h-px bg-border" role="separator" />
                              {children.map((child, i) => (
                                <a
                                  href={child.href}
                                  class={cn(
                                    'flex items-center px-3 py-2 text-sm rounded-md transition-colors',
                                    'hover:bg-secondary focus:bg-secondary',
                                    'text-foreground-secondary hover:text-foreground',
                                    'focus-visible:ring-2 focus-visible:ring-ring outline-none'
                                  )}
                                  role="menuitem"
                                  tabindex={0}
                                  data-dropdown-item={i + 1}
                                >
                                  {child.label}
                                </a>
                              ))}
                            </div>
                          </div>
                        );
                      }
                      return (
                        <a
                          href={href.startsWith('#') && !isLandingPage ? `/${href}` : href}
                          class={cn(
                            'nav-link relative rounded-md px-3 py-2 text-sm',
                            'transition-all duration-(--transition-fast)',
                            isFloating && 'hdr-invert-text',
                            isFloating
                              ? isActive(href)
                                ? 'hdr-nav-active font-semibold'
                                : 'font-medium'
                              : isActive(href)
                                ? 'nav-link-active bg-secondary text-foreground font-semibold'
                                : 'nav-link-inactive text-foreground-muted hover:bg-secondary/70 hover:text-foreground font-medium'
                          )}
                          aria-current={isActive(href) ? 'page' : undefined}
                        >
                          {label}
                        </a>
                      );
                    })}
                  </nav>
                ))
            }

            <div class="hidden items-center gap-2 lg:flex">
              {actions.map((action) => (
                <Button
                  variant="ghost"
                  size="sm"
                  icon={action.iconOnly}
                  href={action.href}
                  target={action.target}
                  aria-label={action.label}
                  class={isFloating ? 'hdr-invert-text' : undefined}
                >
                  <Icon name={action.icon} size="sm" />
                  {!action.iconOnly && action.label}
                </Button>
              ))}

              {showCta && (
                <Button
                  size="sm"
                  href={ctaHref}
                  target={ctaHref?.startsWith('http') ? '_blank' : undefined}
                  class={isFloating ? 'hdr-invert-cta rounded-full' : undefined}
                >
                  {cta.icon && <Icon name={cta.icon} size="sm" />}
                  {cta.label}
                  {cta.trailingIcon && <Icon name={cta.trailingIcon} size="sm" />}
                </Button>
              )}
            </div>
          </>
        )
      }

      {
        showMobileMenu && layout !== 'minimal' && (
          <button
            type="button"
            id={buttonId}
            class={cn(
              'hdr-hamburger inline-flex items-center justify-center rounded-md p-2 lg:hidden',
              'transition-colors',
              'focus-visible:ring-ring focus-visible:ring-2 focus-visible:outline-none',
              isFloating
                ? 'hdr-invert-text hover:bg-secondary/40'
                : 'text-foreground hover:bg-secondary'
            )}
            aria-expanded="false"
            aria-controls={menuId}
            aria-label="Toggle menu"
          >
            <span class="menu-icon">
              <Icon name="menu" size="md" />
            </span>
            <span class="close-icon hidden">
              <Icon name="x" size="md" />
            </span>
          </button>
        )
      }
    </div>
  </div>

  {
    showScrollProgress && (
      <div
        id="scroll-progress-bar"
        class={`bg-brand-500 absolute left-0 h-[2px] w-0 transition-none ${scrollProgressPosition === 'top' ? 'top-0' : 'bottom-0'}`}
        aria-hidden="true"
      />
    )
  }
</header>

{
  showMobileMenu &&
    layout !== 'minimal' &&
    (hasMobileMenuSlot ? (
      <div
        id={menuId}
        class="bg-background fixed inset-0 z-50 hidden lg:hidden"
        role="navigation"
        aria-label="Mobile navigation"
      >
        <div class="mx-auto flex h-full w-full max-w-6xl flex-col">
          <div class="flex h-16 items-center justify-between px-6">
            <a href="/" class="flex items-center gap-2" aria-label={logoText || siteConfig.name}>
              <img
                src="/backstage-logo.webp"
                alt="Backstage"
                width="280"
                height="33"
                class="h-8 w-auto"
                loading="eager"
                decoding="async"
              />
            </a>
            <button
              type="button"
              class="text-foreground-muted hover:bg-secondary hover:text-foreground focus-visible:ring-ring inline-flex items-center justify-center rounded-md p-2 transition-colors focus-visible:ring-2 focus-visible:outline-none"
              aria-label="Close menu"
              data-menu-close
            >
              <Icon name="x" size="md" />
            </button>
          </div>

          <div class="mobile-menu-body flex-1 overflow-y-auto px-6 pt-4 pb-8">
            <slot name="mobile-menu" />
          </div>
        </div>
      </div>
    ) : (
      <div
        id={menuId}
        class="bg-background fixed inset-0 z-50 hidden lg:hidden"
        role="navigation"
        aria-label="Mobile navigation"
      >
        <div class="mx-auto flex h-full w-full max-w-6xl flex-col">
          <div class="flex h-16 items-center justify-between px-6">
            <a href="/" class="flex items-center gap-2" aria-label={logoText || siteConfig.name}>
              <img
                src="/backstage-logo.webp"
                alt="Backstage"
                width="280"
                height="33"
                class="h-8 w-auto"
                loading="eager"
                decoding="async"
              />
            </a>
            <button
              type="button"
              class="text-foreground-muted hover:bg-secondary hover:text-foreground focus-visible:ring-ring inline-flex items-center justify-center rounded-md p-2 transition-colors focus-visible:ring-2 focus-visible:outline-none"
              aria-label="Close menu"
              data-menu-close
            >
              <Icon name="x" size="md" />
            </button>
          </div>

          <div class="mobile-menu-body flex-1 overflow-y-auto px-6 pt-4 pb-8">
            <section class="mobile-menu-section">
              <ul class="space-y-1">
                {navItems.map(({ label, href, children }) => {
                  const active = isActive(href);
                  const resolvedHref = href.startsWith('#') && !isLandingPage ? `/${href}` : href;
                  const hasChildren = children && children.length > 0;
                  if (hasChildren) {
                    const submenuId = `submenu-${Math.random().toString(36).slice(2, 9)}`;
                    return (
                      <li data-mobile-has-submenu>
                        <div class="flex items-center gap-3">
                          <a
                            href={resolvedHref}
                            class={cn(
                              'mobile-menu-row group flex-1 flex items-center gap-3 rounded-xl px-3 py-3 text-base transition-colors',
                              active ? 'mobile-menu-row-active' : 'mobile-menu-row-inactive'
                            )}
                            aria-current={active ? 'page' : undefined}
                          >
                            <span class="mobile-menu-tile">
                              <Icon name="sparkles" size="sm" />
                            </span>
                            <span class="flex-1">{label}</span>
                          </a>
                          <button
                            type="button"
                            class="mobile-submenu-toggle text-foreground-muted hover:text-foreground rounded-md p-2 transition-colors"
                            aria-expanded="false"
                            aria-controls={submenuId}
                            aria-label={`Afficher les sous-menus de ${label}`}
                            data-submenu-trigger
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mobile-submenu-chevron h-4 w-4 transition-transform duration-200" aria-hidden="true">
                              <path d="M6 9l6 6 6-6" />
                            </svg>
                          </button>
                        </div>
                        <ul
                          id={submenuId}
                          class="mobile-submenu ml-12 mt-1 space-y-1"
                          role="menu"
                          style="max-height: 0; overflow: hidden;"
                        >
                          {children.map((child) => (
                            <li>
                              <a
                                href={child.href}
                                class={cn(
                                  'mobile-menu-row group flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm transition-colors',
                                  currentPath === child.href ? 'mobile-menu-row-active' : 'mobile-menu-row-inactive'
                                )}
                                role="menuitem"
                                aria-current={currentPath === child.href ? 'page' : undefined}
                              >
                                <span class="flex-1">{child.label}</span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </li>
                    );
                  }
                  return (
                    <li>
                      <a
                        href={resolvedHref}
                        class={cn(
                          'mobile-menu-row group flex items-center gap-3 rounded-xl px-3 py-3 text-base transition-colors',
                          active ? 'mobile-menu-row-active' : 'mobile-menu-row-inactive'
                        )}
                        aria-current={active ? 'page' : undefined}
                      >
                        <span class="mobile-menu-tile">
                          {href.startsWith('/diagnostic') ? (
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              viewBox="0 -960 960 960"
                              fill="currentColor"
                              class="h-4 w-4"
                              aria-hidden="true"
                            >
                              <path d="M824 -80 716 -188Q694 -175 670.0 -167.5Q646 -160 620 -160Q545 -160 492.5 -212.5Q440 -265 440.0 -340.0Q440 -415 492.5 -467.5Q545 -520 620.0 -520.0Q695 -520 747.5 -467.5Q800 -415 800 -340Q800 -314 792.5 -290.0Q785 -266 772 -244L880 -136ZM620.0 -240.0Q662 -240 691.0 -269.0Q720 -298 720.0 -340.0Q720 -382 691.0 -411.0Q662 -440 620.0 -440.0Q578 -440 549.0 -411.0Q520 -382 520.0 -340.0Q520 -298 549.0 -269.0Q578 -240 620.0 -240.0ZM840 -560H760V-760Q760 -760 760.0 -760.0Q760 -760 760 -760H680V-640H280V-760H200Q200 -760 200.0 -760.0Q200 -760 200 -760V-200Q200 -200 200.0 -200.0Q200 -200 200 -200H400V-120H200Q167 -120 143.5 -143.5Q120 -167 120 -200V-760Q120 -793 143.5 -816.5Q167 -840 200 -840H367Q378 -875 410.0 -897.5Q442 -920 480 -920Q520 -920 551.5 -897.5Q583 -875 594 -840H760Q793 -840 816.5 -816.5Q840 -793 840 -760ZM480.0 -760.0Q497 -760 508.5 -771.5Q520 -783 520.0 -800.0Q520 -817 508.5 -828.5Q497 -840 480.0 -840.0Q463 -840 451.5 -828.5Q440 -817 440.0 -800.0Q440 -783 451.5 -771.5Q463 -760 480.0 -760.0Z" />
                            </svg>
                          ) : href.startsWith('/prestations') ? (
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              viewBox="0 -960 960 960"
                              fill="currentColor"
                              class="h-4 w-4"
                              aria-hidden="true"
                            >
                              <path d="M160 -120Q127 -120 103.5 -143.5Q80 -167 80 -200V-760Q80 -793 103.5 -816.5Q127 -840 160 -840H720Q753 -840 776.5 -816.5Q800 -793 800 -760V-680H880V-600H800V-520H880V-440H800V-360H880V-280H800V-200Q800 -167 776.5 -143.5Q753 -120 720 -120ZM160 -200H720Q720 -200 720.0 -200.0Q720 -200 720 -200V-760Q720 -760 720.0 -760.0Q720 -760 720 -760H160Q160 -760 160.0 -760.0Q160 -760 160 -760V-200Q160 -200 160.0 -200.0Q160 -200 160 -200ZM240 -280H440V-440H240ZM480 -560H640V-680H480ZM240 -480H440V-680H240ZM480 -280H640V-520H480ZM160 -760Q160 -760 160.0 -760.0Q160 -760 160 -760V-200Q160 -200 160.0 -200.0Q160 -200 160 -200Q160 -200 160.0 -200.0Q160 -200 160 -200V-760Q160 -760 160.0 -760.0Q160 -760 160 -760Z" />
                            </svg>
                          ) : (
                            <Icon name={getNavIcon(href)} size="sm" />
                          )}
                        </span>
                        <span class="flex-1">{label}</span>
                        <Icon name="chevron-right" size="sm" class="mobile-menu-chevron" />
                      </a>
                    </li>
                  );
                })}
              </ul>
            </section>

            {showCta && (
              <div class="mobile-menu-cta-wrap pt-4">
                <Button
                  fullWidth
                  href={ctaHref}
                  target={ctaHref?.startsWith('http') ? '_blank' : undefined}
                >
                  {cta.icon && <Icon name={cta.icon} size="sm" />}
                  {cta.label}
                  {cta.trailingIcon && <Icon name={cta.trailingIcon} size="sm" />}
                </Button>
              </div>
            )}
          </div>
        </div>
      </div>
    ))
}

{
  showMobileMenu && layout !== 'minimal' && (
    <div
      id={`${menuId}-backdrop`}
      class="pointer-events-none fixed inset-0 z-40 opacity-0 transition-opacity duration-200 lg:hidden"
      aria-hidden="true"
    />
  )
}

<script>
  function initMobileMenu() {
    const menuHeaders = document.querySelectorAll<HTMLElement>('header[data-menu-id]');
    menuHeaders.forEach((header) => {
      const menuId = header.dataset.menuId!;
      const buttonId = header.dataset.buttonId!;
      const isFloating = header.dataset.headerShape === 'floating';

      const button = document.getElementById(buttonId);
      const menu = document.getElementById(menuId);
      const backdrop = document.getElementById(`${menuId}-backdrop`);
      const menuIcon = button?.querySelector('.menu-icon');
      const closeIcon = button?.querySelector('.close-icon');

      if (!button || !menu || !menuIcon || !closeIcon) return;
      if (button.dataset.menuInit) return;
      button.dataset.menuInit = 'true';

      let isOpen = false;

      function open() {
        if (isOpen) return;
        isOpen = true;

        button!.setAttribute('aria-expanded', 'true');
        menuIcon!.classList.add('hidden');
        closeIcon!.classList.remove('hidden');

        if (isFloating) {
          header.setAttribute('data-scrolled', '');
        } else {
          header.classList.add('!bg-background');
        }

        document.documentElement.style.overflow = 'hidden';

        const mainContent = document.querySelector('main');
        const footer = document.querySelector('footer');
        if (mainContent) mainContent.classList.add('mobile-menu-blur');
        if (footer) footer.classList.add('mobile-menu-blur');

        menu!.classList.remove('hidden');
        menu!.classList.add('block');
        if (backdrop) {
          backdrop.classList.remove('pointer-events-none', 'animate-backdrop-out');
          backdrop.classList.add('animate-backdrop');
        }
      }

      function close() {
        if (!isOpen) return;
        isOpen = false;

        button!.setAttribute('aria-expanded', 'false');
        menuIcon!.classList.remove('hidden');
        closeIcon!.classList.add('hidden');

        menu!.classList.remove('block');
        menu!.classList.add('hidden');

        document.documentElement.style.overflow = '';

        const mainContent = document.querySelector('main');
        const footer = document.querySelector('footer');
        if (mainContent) mainContent.classList.remove('mobile-menu-blur');
        if (footer) footer.classList.remove('mobile-menu-blur');

        if (backdrop) {
          backdrop.classList.remove('animate-backdrop');
          backdrop.classList.add('animate-backdrop-out', 'pointer-events-none');
        }

        if (!isFloating) {
          header.classList.remove('!bg-background');
        } else if (window.scrollY <= 60) {
          header.removeAttribute('data-scrolled');
        }
      }

      function toggle() {
        if (isOpen) {
          close();
        } else {
          open();
        }
      }

      button.addEventListener('click', toggle);

      if (backdrop) {
        backdrop.addEventListener('click', close);
      }

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && isOpen) {
          close();
        }
      });

      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', close);
      });

      menu.querySelectorAll('[data-menu-close]').forEach((closeButton) => {
        closeButton.addEventListener('click', close);
      });
    });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>

<script>
  const SCROLL_THRESHOLD = 60;
  const AUTO_HIDE_THRESHOLD = 150;
  const BAR_SCROLLED_CLASSES = [
    'bg-background/80',
    'backdrop-blur-lg',
    'border-b',
    'border-border/50',
  ];

  function initScrollDriven() {
    const scrollHeaders = document.querySelectorAll<HTMLElement>(
      'header[data-header-shape="floating"], header[data-header-shape="bar"]'
    );

    scrollHeaders.forEach((header) => {
      if (header.dataset.scrollInit) return;
      header.dataset.scrollInit = 'true';

      const isBar = header.dataset.headerShape === 'bar';
      const isFloating = header.dataset.headerShape === 'floating';
      const isAutoHide = header.dataset.headerAutoHide === 'true';
      const isTransparentBar = isBar && header.dataset.headerVariant === 'transparent';

      let ticking = false;
      let lastScrollY = window.scrollY;

      function onScroll() {
        if (ticking) return;
        ticking = true;

        requestAnimationFrame(() => {
          const currentScrollY = window.scrollY;
          const menuId = header.dataset.menuId;
          const menu = menuId ? document.getElementById(menuId) : null;
          const menuOpen = menu && !menu.classList.contains('hidden');

          if (currentScrollY > SCROLL_THRESHOLD) {
            header.setAttribute('data-scrolled', '');
            if (isTransparentBar) {
              header.classList.add(...BAR_SCROLLED_CLASSES);
              header.classList.remove('bg-transparent');
            }
          } else if (!menuOpen) {
            header.removeAttribute('data-scrolled');
            header.removeAttribute('data-header-hidden');
            if (isTransparentBar) {
              header.classList.remove(...BAR_SCROLLED_CLASSES);
              header.classList.add('bg-transparent');
            }
          }

          if (isFloating && isAutoHide && !menuOpen) {
            if (currentScrollY > AUTO_HIDE_THRESHOLD && currentScrollY > lastScrollY) {
              header.setAttribute('data-header-hidden', '');
            } else {
              header.removeAttribute('data-header-hidden');
            }
          } else {
            header.removeAttribute('data-header-hidden');
          }

          lastScrollY = currentScrollY;
          ticking = false;
        });
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      requestAnimationFrame(onScroll);
    });
  }

  initScrollDriven();
  document.addEventListener('astro:page-load', initScrollDriven);
  document.addEventListener('astro:after-swap', initScrollDriven);
</script>

<script>
  function initNavDropdowns() {
    document.querySelectorAll<HTMLElement>('[data-nav-dropdown]').forEach((wrapper) => {
      const trigger = wrapper.querySelector<HTMLElement>('[data-dropdown-trigger]');
      const panel = wrapper.querySelector<HTMLElement>('[data-dropdown-menu]');
      if (!trigger || !panel) return;

      const items = panel.querySelectorAll<HTMLElement>('[data-dropdown-item]');
      let open = false;

      function openDropdown() {
        open = true;
        wrapper.setAttribute('data-open', '');
        trigger.setAttribute('aria-expanded', 'true');
        if (items.length > 0) items[0].focus();
      }

      function closeDropdown(returnFocus = true) {
        open = false;
        wrapper.removeAttribute('data-open');
        trigger.setAttribute('aria-expanded', 'false');
        if (returnFocus) trigger.focus();
      }

      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        open ? closeDropdown(false) : openDropdown();
      });

      trigger.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
          e.preventDefault();
          openDropdown();
        }
        if (e.key === 'ArrowUp') {
          e.preventDefault();
          openDropdown();
        }
      });

      panel.addEventListener('keydown', (e) => {
        const current = document.activeElement as HTMLElement;
        const idx = Array.from(items).indexOf(current);

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          const next = idx < items.length - 1 ? idx + 1 : 0;
          items[next].focus();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          const prev = idx > 0 ? idx - 1 : items.length - 1;
          items[prev].focus();
        } else if (e.key === 'Escape') {
          e.preventDefault();
          closeDropdown();
        } else if (e.key === 'Tab') {
          closeDropdown(false);
        } else if (e.key === 'Home') {
          e.preventDefault();
          items[0].focus();
        } else if (e.key === 'End') {
          e.preventDefault();
          items[items.length - 1].focus();
        }
      });

      wrapper.addEventListener('mouseleave', () => {
        if (open) closeDropdown(false);
      });
    });
  }

  function initMobileSubmenus() {
    document.querySelectorAll<HTMLElement>('[data-submenu-trigger]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        const targetId = btn.getAttribute('aria-controls');
        const target = targetId ? document.getElementById(targetId) : null;
        if (!target) return;

        btn.setAttribute('aria-expanded', String(!expanded));
        if (expanded) {
          target.style.maxHeight = '0';
        } else {
          target.style.maxHeight = target.scrollHeight + 'px';
        }
      });
    });
  }

  initNavDropdowns();
  initMobileSubmenus();
  document.addEventListener('astro:page-load', () => {
    initNavDropdowns();
    initMobileSubmenus();
  });
  document.addEventListener('astro:after-swap', () => {
    initNavDropdowns();
    initMobileSubmenus();
  });
</script>

