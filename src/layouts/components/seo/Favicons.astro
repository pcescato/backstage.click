---
import config from ".astro/config.generated.json";

const favicons: {
  rel: string;
  type?: string;
  sizes?: string;
  href: string;
  color?: string;
}[] = [
  {
    rel: "apple-touch-icon",
    sizes: "180x180",
    href: "/images/favicons/apple-touch-icon.png",
  },
  {
    rel: "icon",
    type: "image/png",
    sizes: "96x96",
    href: "/images/favicons/favicon-96x96.png",
  },
  {
    rel: "icon",
    type: "image/png",
    sizes: "192x192",
    href: "/images/favicons/web-app-manifest-192x192.png",
  },
  {
    rel: "icon",
    type: "image/png",
    sizes: "512x512",
    href: "/images/favicons/web-app-manifest-512x512.png",
  },
  {
    rel: "icon",
    type: "image/webp",
    sizes: "512x512",
    href: "/backstage-favicon.webp",
  },
  {
    rel: "shortcut icon",
    href: "/images/favicons/favicon.ico",
  },
  {
    rel: "manifest",
    href: "/images/favicons/site.webmanifest",
  },
];

const metaTags = [
  { color: "msapplication-TileColor", content: "#ffffff" },
  { name: "apple-mobile-web-app-title", content: config.site.title },
];
---

<!------------------------ Favicons ------------------------>{
  favicons.map((favicon) => (
    <link
      rel={favicon.rel}
      type={favicon.type}
      sizes={favicon.sizes}
      href={favicon.href}
      color={favicon.color}
    />
  ))
}

{metaTags.map((meta) => <meta name={meta.name} content={meta.content} />)}
