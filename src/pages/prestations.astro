---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import { footerNavItems, legalLinks } from '@/config/nav.config';

interface ServiceCard {
  title: string;
  description: string;
  iconPath: string;
  href: string;
}

const services: ServiceCard[] = [
  {
    title: 'CRM & ERP sur-mesure pour PME',
    description:
      "Développement d'applications métier sur-mesure : ERP Qualiopi, CRM/SAV terrain. PHP natif, sans ORM, sans abonnement SaaS. Réalisations : GCF Pro, sav-crm.",
    iconPath:
      'M160-160q-33 0-56.5-23.5T80-240v-480q0-33 23.5-56.5T160-800h640q33 0 56.5 23.5T880-720v480q0 33-23.5 56.5T800-160H160Zm0-80h640v-400H160v400Zm140-40-56-56 103-104-104-104 57-56 160 160-160 160Zm180 0v-80h240v80H480Z',
    href: '/prestations/crm-erp-pme',
  },
  {
    title: 'WordPress : maintenance, optimisation et migration',
    description:
      'Sécurisation, Core Web Vitals, migration vers Astro ou Hugo via pipeline propriétaire wp2md. Préservation SEO, réduction du temps de migration de 80%.',
    iconPath:
      'm226-559 78 33q14-28 29-54t33-52l-56-11-84 84Zm142 83 114 113q42-16 90-49t90-75q70-70 109.5-155.5T806-800q-72-5-158 34.5T492-656q-42 42-75 90t-49 90Zm155-121.5q0-33.5 23-56.5t57-23q34 0 57 23t23 56.5q0 33.5-23 56.5t-57 23q-34 0-57-23t-23-56.5ZM565-220l84-84-11-56q-26 18-52 32.5T532-299l33 79Zm313-653q19 121-23.5 235.5T708-419l20 99q4 20-2 39t-20 33L538-80l-84-197-171-171-197-84 167-168q14-14 33.5-20t39.5-2l99 20q104-104 218-147t235-24ZM157-321q35-35 85.5-35.5T328-322q35 35 34.5 85.5T327-151q-25 25-83.5 43T82-76q14-103 32-161.5t43-83.5Zm57 56q-10 10-20 36.5T180-175q27-4 53.5-13.5T270-208q12-12 13-29t-11-29q-12-12-29-11.5T214-265Z',
    href: '/prestations/wordpress',
  },
  {
    title: 'DevOps : déploiement et hébergement',
    description:
      'Linux, Docker, Nginx, Caddy, LiteSpeed. Déploiement automatisé, sauvegardes multi-destinations, monitoring. Ce site est déployé via ce pipeline.',
    iconPath:
      'M120-160v-160h720v160H120Zm80-40h80v-80h-80v80Zm-80-440v-160h720v160H120Zm80-40h80v-80h-80v80Zm-80 280v-160h720v160H120Zm80-40h80v-80h-80v80Z',
    href: '/prestations/devops-deploiement',
  },
  {
    title: 'IA & automatisation',
    description:
      "Intégration LLM (OpenAI, Ollama local), automatisation avec n8n, maîtrise des coûts via OpenRouter. L'IA assiste, elle ne décide jamais seule.",
    iconPath:
      'M440-120H200q-33 0-56.5-23.5T120-200v-560q0-33 23.5-56.5T200-840h240v720Zm-80-80v-560H200v560h160Zm160-320v-320h240q33 0 56.5 23.5T840-760v240H520Zm80-80h160v-160H600v160Zm-80 480v-320h320v240q0 33-23.5 56.5T760-120H520Zm80-80h160v-160H600v160Z',
    href: '/prestations/ia-automatisation',
  },
] as const;

const certifications = [
  'Zend Certified Engineer PHP 5',
  'Conception de SI – Niveau Master',
  'Formation de formateurs – GRETA',
] as const;

const verifiedIconPath =
  'm344-60-76-128-144-32 14-148-98-112 98-112-14-148 144-32 76-128 136 58 136-58 76 128 144 32-14 148 98 112-98 112 14 148-144 32-76 128-136-58-136 58Zm34-102 102-44 104 44 56-96 110-26-10-112 74-84-74-86 10-112-110-24-58-96-102 44-104-44-56 96-110 24 10 112-74 86 74 84-10 114 110 24 58 96Zm60-176-142-142 56-56 86 84 170-170 56 58-226 226Z';
---

<BaseLayout
  title="Prestations"
  description="Prestations de développement, conseil, DevOps et automatisation pour projets web et applications métier."
>
  <Header slot="header" position="fixed" size="lg" showActiveState showCta={false} actions={[]} />

  <div class="min-h-screen pt-16">
    <Hero
      layout="centered"
      size="lg"
      showGrid
      class="border-border border-b pt-12 pb-6 md:pt-20 md:pb-12"
    >
      <Badge slot="badge" variant="brand" pill class="px-3 py-1 text-sm">
        Développement & conseil
      </Badge>

      <h1 slot="title" class="!leading-[1.05] !text-4xl md:!text-5xl lg:!text-6xl">
        20 ans de production réelle.
        <br />
        Pas de théorie d'agence.
      </h1>

      <p slot="description" class="max-w-6xl">
        Développeur full-stack indépendant. J'interviens de l'analyse à la mise en
        production – sans intermédiaire, sans délégation des décisions techniques.
      </p>
    </Hero>

    <section class="border-border bg-background border-b py-20">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto mb-12 max-w-6xl text-center">
          <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
            Prestations
          </h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          {
            services.map((service) => (
              <Card variant="elevated" padding="lg" href={service.href} hover class="border-border h-full border">
                <div class="flex h-full flex-col gap-5">
                  <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 -960 960 960"
                      fill="currentColor"
                      class="h-12 w-12 shrink-0"
                      aria-hidden="true"
                    >
                      <path d={service.iconPath}></path>
                    </svg>
                  </div>

                  <div class="space-y-3">
                    <h3 class="font-display text-foreground text-xl md:text-2xl font-bold">
                      {service.title}
                    </h3>
                    <p class="text-foreground-muted text-sm md:text-base leading-relaxed">{service.description}</p>
                  </div>
                </div>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-border bg-background-secondary border-b py-20">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto max-w-6xl text-center">
          <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
            Certifications & formation
          </h2>
        </div>

        <div class="mt-12 flex flex-wrap justify-center gap-4">
          {
            certifications.map((item) => (
              <div class="border-border bg-background text-foreground inline-flex items-center gap-3 rounded-full border px-4 py-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 -960 960 960"
                  fill="currentColor"
                  class="h-12 w-12 shrink-0"
                  aria-hidden="true"
                >
                  <path d={verifiedIconPath}></path>
                </svg>
                <span class="text-sm font-medium leading-relaxed">{item}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="invert-section bg-background border-t border-border py-20">
      <div class="mx-auto max-w-6xl px-6 text-center">
        <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
          Un projet ? Parlons-en.
        </h2>
        <p class="text-foreground-muted mt-6 text-lg leading-relaxed">
          15 minutes suffisent pour faire le point sur vos besoins et voir si je peux vous aider.
        </p>
        <div class="mt-10 flex justify-center">
          <Button href="/contact">Prendre rendez-vous →</Button>
        </div>
      </div>
    </section>
  </div>

  <Footer slot="footer" layout="simple" nav={footerNavItems} legalLinks={legalLinks} />
</BaseLayout>
