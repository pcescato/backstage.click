---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { footerNavItems, legalLinks } from '@/config/nav.config';
---

<BaseLayout
  title="Mentions légales"
  description="Mentions légales du site backstage.click."
>
  <Header slot="header" position="fixed" size="lg" showActiveState showCta={false} actions={[]} />

  <div class="min-h-screen pt-24">
    <section class="bg-background py-16">
      <div class="mx-auto max-w-3xl px-6">
        <h1 class="font-display text-foreground text-4xl font-bold tracking-tight md:text-5xl">
          Mentions légales
        </h1>

        <div class="text-foreground-muted mt-12 space-y-10 leading-relaxed">
          <section class="space-y-4">
            <h2 class="font-display text-foreground text-2xl font-bold">Éditeur du site</h2>
            <p>
              Pascal Cescato
              <br />
              Auto-entrepreneur
              <br />
              21 place de la Libération – 47210 Villeréal
              <br />
              SIRET : En cours d'enregistrement
              <br />
              Email : courriel@backstage.click
              <br />
              Site : https://backstage.click
            </p>
          </section>

          <section class="space-y-4">
            <h2 class="font-display text-foreground text-2xl font-bold">Hébergement</h2>
            <p>
              Hébergeur : Layer7
              <br />
              Layer7 Networks GmbH
              <br />
              Brunnenstrasse 9a
              <br />
              63599 Biebergemünd
              <br />
              Allemagne
            </p>
          </section>

          <section class="space-y-4">
            <h2 class="font-display text-foreground text-2xl font-bold">
              Propriété intellectuelle
            </h2>
            <p>
              L'ensemble du contenu de ce site (textes, visuels, structure) est la propriété
              exclusive de Pascal Cescato. Toute reproduction, même partielle, est interdite sans
              autorisation préalable.
            </p>
          </section>

          <section class="space-y-4">
            <h2 class="font-display text-foreground text-2xl font-bold">Données personnelles</h2>
            <p>
              Ce site ne collecte aucune donnée personnelle à des fins commerciales. Les données
              transmises via le formulaire de contact sont utilisées uniquement pour répondre à
              votre demande.
            </p>
          </section>

          <section class="space-y-4">
            <h2 class="font-display text-foreground text-2xl font-bold">Cookies</h2>
            <p>
              Ce site utilise un cookie fonctionnel pour mémoriser vos préférences de consentement.
              Aucun cookie publicitaire ou de tracking n'est déposé sans votre accord.
            </p>
          </section>
        </div>
      </div>
    </section>
  </div>

  <Footer slot="footer" layout="simple" nav={footerNavItems} legalLinks={legalLinks} />
</BaseLayout>
