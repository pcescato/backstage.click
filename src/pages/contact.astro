---
import Base from "@/layouts/Base.astro";
---

<Base
  title="Contact"
  metaTitle="Contact – Backstage"
  metaDescription="Réserver un créneau ou écrire directement pour échanger sur votre projet."
  headerLayout="two"
  headerPosition="fixed"
>
  <div class="min-h-screen pt-16">
    <section class="border-border border-b pt-12 pb-6 md:pt-20 md:pb-12">
      <div class="mx-auto max-w-6xl px-6 text-center">
        <span class="bg-brand-500/10 text-brand-500 inline-flex items-center rounded-full px-3 py-1 text-sm font-medium">Contact</span>
        <h1 class="font-display text-foreground max-w-4xl !leading-[1.05] mt-6 !text-4xl md:!text-5xl lg:!text-6xl">
          Réserver un créneau ou écrire directement
        </h1>
        <p class="text-foreground-muted mx-auto mt-6 max-w-3xl">
          15 minutes suffisent pour faire le point.
        </p>
      </div>
    </section>

    <section class="border-border bg-background border-b py-20">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <button id="tab-rendez-vous" class="w-full rounded-t-xl border border-b-0 border-border bg-card px-6 py-3 text-left text-sm font-semibold text-foreground transition-colors" onclick="document.getElementById('tab-rendez-vous').classList.add('bg-card','text-foreground');document.getElementById('tab-message').classList.remove('bg-card','text-foreground');document.getElementById('tab-message').classList.add('bg-transparent','text-foreground-muted');document.getElementById('content-rendez-vous').classList.remove('hidden');document.getElementById('content-message').classList.add('hidden');">
              Prendre rendez-vous
            </button>
          </div>
          <div>
            <button id="tab-message" class="w-full rounded-t-xl border border-b-0 border-border bg-transparent px-6 py-3 text-left text-sm font-semibold text-foreground-muted transition-colors" onclick="document.getElementById('tab-message').classList.add('bg-card','text-foreground');document.getElementById('tab-rendez-vous').classList.remove('bg-card','text-foreground');document.getElementById('tab-rendez-vous').classList.add('bg-transparent','text-foreground-muted');document.getElementById('content-message').classList.remove('hidden');document.getElementById('content-rendez-vous').classList.add('hidden');">
              Écrire un message
            </button>
          </div>
        </div>

        <div id="content-rendez-vous" class="border border-border rounded-b-xl rounded-tr-xl bg-card shadow-lg transition-all duration-200 ease-out">
          <div class="border-border overflow-hidden rounded-xl border bg-card shadow-lg transition-all duration-200 ease-out">
            <!-- Début de widget en ligne Calendly -->
            <div class="calendly-inline-widget" data-url="https://calendly.com/backstage-click/15min" style="min-width:320px;height:700px;"></div>
            <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
            <!-- Fin de widget en ligne Calendly -->
          </div>
        </div>

        <div id="content-message" class="hidden border border-border rounded-b-xl rounded-tr-xl bg-card p-8 shadow-lg transition-all duration-200 ease-out">
          <form id="contact-form" action="/api/contact.php" method="POST" class="space-y-4">
            <div class="grid gap-4 md:grid-cols-2">
              <div class="space-y-1.5">
                <label for="contact-nom" class="text-sm font-medium leading-none">Nom *</label>
                <input
                  id="contact-nom"
                  name="nom"
                  type="text"
                  required
                  autocomplete="name"
                  class="h-10 w-full rounded-lg border border-border bg-background pl-4 pr-4 text-sm transition-colors duration-(--transition-fast) placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50"
                />
              </div>

              <div class="space-y-1.5">
                <label for="contact-email" class="text-sm font-medium leading-none">
                  Email *
                </label>
                <input
                  id="contact-email"
                  name="email"
                  type="email"
                  required
                  autocomplete="email"
                  class="h-10 w-full rounded-lg border border-border bg-background pl-4 pr-4 text-sm transition-colors duration-(--transition-fast) placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50"
                />
              </div>
            </div>

            <div class="space-y-1.5">
              <label for="contact-sujet" class="text-sm font-medium leading-none">Sujet</label>
              <input
                id="contact-sujet"
                name="sujet"
                type="text"
                class="h-10 w-full rounded-lg border border-border bg-background pl-4 pr-4 text-sm transition-colors duration-(--transition-fast) placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50"
              />
            </div>

            <div class="space-y-1.5">
              <label for="contact-message" class="text-sm font-medium leading-none">
                Message *
              </label>
              <textarea
                id="contact-message"
                name="message"
                rows="5"
                required
                class="min-h-[80px] w-full resize-y rounded-lg border border-border bg-background px-4 py-3 text-sm transition-colors duration-(--transition-fast) placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50"
              ></textarea>
            </div>

            <div style="position:absolute;left:-9999px" aria-hidden="true">
              <input type="text" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <label class="flex items-start gap-2 text-sm font-medium">
              <input type="checkbox" name="rgpd_consent" required class="mt-0.5 h-4 w-4 rounded border-border text-primary focus:ring-primary" />
              <span class="text-foreground">
                J'accepte la <a href="/politique-confidentialite" target="_blank" rel="noopener noreferrer" class="text-primary underline hover:text-primary/80 transition-colors">politique de confidentialité</a> *
              </span>
            </label>

            <div id="contact-error" class="hidden text-sm text-destructive"></div>

            <button type="submit" id="contact-submit" class="btn btn-primary w-full">
              Envoyer →
            </button>
          </form>

          <div id="contact-success" class="hidden text-center text-sm text-success">
            Message envoyé. Je vous réponds sous 24h.
          </div>
        </div>
      </div>
    </section>

    <section class="border-border bg-background-secondary border-b py-20">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid gap-6 md:grid-cols-3">
          <div class="border-border rounded-xl border bg-background p-6 text-center">
            <p class="text-foreground-muted text-sm font-medium">Email</p>
            <a
              href="mailto:courriel@backstage.click"
              class="text-foreground mt-3 inline-flex text-lg font-semibold hover:underline"
            >
              courriel@backstage.click
            </a>
          </div>

          <div class="border-border rounded-xl border bg-background p-6 text-center">
            <p class="text-foreground-muted text-sm font-medium">Délai de réponse</p>
            <p class="text-foreground mt-3 text-lg font-semibold">Sous 24h en semaine</p>
          </div>

          <div class="border-border rounded-xl border bg-background p-6 text-center">
            <p class="text-foreground-muted text-sm font-medium">Localisation</p>
            <p class="text-foreground mt-3 text-lg font-semibold">
              Full remote
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    function initContactForm() {
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      const button = document.getElementById('contact-submit') as HTMLButtonElement | null;
      const success = document.getElementById('contact-success') as HTMLDivElement | null;
      const error = document.getElementById('contact-error') as HTMLDivElement | null;

      if (!form || !button || !success || !error) return;
      if (form.dataset.formInit) return;
      form.dataset.formInit = 'true';

      const defaultLabel = 'Envoyer →';
      const defaultSuccessMessage =
        success.textContent?.trim() || 'Message envoyé. Je vous réponds sous 24h.';

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        button.disabled = true;
        button.textContent = 'Envoi...';
        error.classList.add('hidden');
        success.classList.add('hidden');

        try {
          const formData = new FormData(form);
          const payload = {
            nom: String(formData.get('nom') ?? ''),
            email: String(formData.get('email') ?? ''),
            sujet: String(formData.get('sujet') ?? ''),
            message: String(formData.get('message') ?? ''),
            website: String(formData.get('website') ?? ''),
            rgpd_consent: formData.get('rgpd_consent') === 'on',
          };

          const response = await fetch('/api/contact.php', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(payload),
          });

          const data = await response.json();

          if (response.ok && data.success) {
            success.textContent =
              typeof data.message === 'string' && data.message !== ''
                ? data.message
                : defaultSuccessMessage;
            form.classList.add('hidden');
            success.classList.remove('hidden');
            form.reset();
            return;
          }

          error.textContent =
            typeof data.message === 'string' && data.message !== ''
              ? data.message
              : 'Une erreur est survenue.';
          error.classList.remove('hidden');
        } catch {
          error.textContent = 'Une erreur est survenue.';
          error.classList.remove('hidden');
        } finally {
          button.disabled = false;
          button.textContent = defaultLabel;
        }
      });
    }

    initContactForm();
    document.addEventListener('astro:after-swap', initContactForm);
  </script>
</Base>
