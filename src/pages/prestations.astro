---
import Base from "@/layouts/Base.astro";
import { getCollection } from "astro:content";
import PageHeader from "@/components/widgets/PageHeader.astro";

const prestations = await getCollection("prestations", ({ id }) => {
  return !id.includes("-index");
});

const pageData = {
  title: "Prestations",
  metaTitle: "Prestations – Backstage",
  metaDescription: "Prestations de développement, conseil, DevOps et automatisation pour projets web et applications métier.",
};
---

<Base {...pageData} fitToScreen={false}>
  <PageHeader
    content={{
      title: pageData.title,
      description: pageData.metaDescription,
    }}
  />

  <section class="section-spacing-vertical">
    <div class="container">
      <div class="grid gap-8 md:grid-cols-2">
        {
          prestations.map((prestation) => (
            <a
              href={`/prestations/${prestation.data.customSlug || prestation.id.split("/").pop()?.replace(/\.(mdx?|MDX?)$/, "")}/`}
              class="group block rounded-2xl border border-border-light bg-white p-8 transition-all duration-300 hover:shadow-card-hover">
              <h3 class="text-h4 text-dark group-hover:text-primary mb-3 font-semibold transition-colors duration-300">
                {prestation.data.title}
              </h3>
              {prestation.data.description && (
                <p class="text-text-default leading-body text-base">
                  {prestation.data.description}
                </p>
              )}
              <span class="text-primary mt-4 inline-flex items-center gap-1 text-sm font-semibold">
                Voir les détails
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform duration-300 group-hover:translate-x-1">
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Base>
