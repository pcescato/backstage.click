---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Hero from '@/components/hero/Hero.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Input from '@/components/ui/form/Input/Input.astro';
import Tabs from '@/components/ui/overlay/Tabs/Tabs.astro';
import Textarea from '@/components/ui/form/Textarea/Textarea.astro';
import { footerNavItems, legalLinks } from '@/config/nav.config';
---

<BaseLayout
  title="Backstage"
  description="Audit, migration et optimisation de sites web pour organismes de formation et TPE/PME."
>
  <Header slot="header" position="fixed" size="lg" showActiveState showCta={false} actions={[]} />

  <main class="min-h-screen pt-16">
    <section class="border-border bg-background border-b">
      <Hero
        layout="split"
        size="xl"
        class="pt-12 pb-8 md:pt-20 [&>div]:items-center [&>div]:gap-12 lg:[&>div]:gap-16 [&>div>div:first-child]:justify-center [&>div>div:first-child]:lg:min-h-[420px] [&>div>div:last-child]:lg:min-h-[420px]"
      >
        <h1 slot="title" class="!leading-[1.05] !text-4xl md:!text-5xl lg:!text-6xl">
          Des architectures numériques plus légères.
          <br />
          Des systèmes plus performants.
        </h1>

        <p slot="description" class="max-w-2xl">
          J'interviens sur les fondations techniques de votre présence web pour les rendre plus
          sobres, plus fiables et plus utiles à votre activité.
        </p>

        <Card
          slot="aside"
          variant="elevated"
          padding="lg"
          class="border-border bg-background-secondary/80 h-full border"
        >
          <div class="flex h-full flex-col justify-center gap-5">
            <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 -960 960 960"
                fill="currentColor"
                class="h-12 w-12 shrink-0"
                aria-hidden="true"
              >
                <path d="M323-160q-11 0-20.5-5.5T288-181l-78-139h58l40 80h92v-40h-68l-40-80H188l-57-100q-2-5-3.5-10t-1.5-10q0-4 5-20l57-100h104l40-80h68v-40h-92l-40 80h-58l78-139q5-10 14.5-15.5T323-800h97q17 0 28.5 11.5T460-760v160h-60l-40 40h100v120h-88l-40-80h-92l-40 40h108l40 80h112v200q0 17-11.5 28.5T420-160h-97Zm237 0q-33 0-56.5-23.5T480-240q0-23 11-40.5t29-28.5v-342q-18-11-29-28.5T480-720q0-33 23.5-56.5T560-800q33 0 56.5 23.5T640-720q0 23-11 40.5T600-651v101l80-48q0-34 23.5-58t56.5-24q33 0 56.5 23.5T840-600q0 33-23.5 56.5T760-520q-11 0-20.5-2.5T721-530l-91 55 101 80q7-3 14-4t15-1q33 0 56.5 23.5T840-320q0 33-23.5 56.5T760-240q-37 0-60.5-28T681-332l-81-65v89q18 11 28.5 28.5T639-240q0 33-23 56.5T560-160Z"></path>
              </svg>
            </div>
            <div class="space-y-3">
              <h2 class="font-display text-foreground text-2xl font-bold">
                Conseil et développement web
              </h2>
              <p class="text-foreground-muted leading-relaxed">
                J'aide les PME et les organismes de formation à reprendre le contrôle de leurs
                outils web. Pas d'over-engineering, pas de jargon inutile : je conçois et
                j'optimise des solutions fluides, rapides et adaptées à votre réalité terrain.
              </p>
            </div>
          </div>
        </Card>
      </Hero>

      <div class="mx-auto max-w-6xl px-6 pb-16 text-center">
        <Button size="lg" href="#services">
          Voir comment ça fonctionne
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 -960 960 960"
            fill="currentColor"
            class="h-4 w-4 shrink-0"
            aria-hidden="true"
          >
            <path d="M647-440H160v-80h487L423-744l57-56 320 320-320 320-57-56 224-224Z"></path>
          </svg>
        </Button>
      </div>
    </section>

    <section class="border-border bg-background-secondary border-b py-20">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
          L'efficacité par la simplicité
        </h2>
        <p class="text-foreground-muted mx-auto mt-6 max-w-3xl text-lg leading-relaxed">
          Un bon système n'est pas un système où l'on a ajouté tout ce qu'on pouvait,
          mais un système dont on a retiré tout ce qui était inutile. Moins de code superflu
          signifie moins de maintenance, plus de sécurité et une vitesse d'exécution maximale.
          La technique doit servir votre métier, pas l'inverse.
        </p>
      </div>
    </section>

    <section id="services" class="border-border bg-background scroll-mt-28 border-b py-20">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
            Services
          </h2>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
          <Card variant="elevated" padding="lg" class="border-border h-full border">
            <div class="flex h-full flex-col gap-6">
              <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 -960 960 960"
                  fill="currentColor"
                  class="h-12 w-12 shrink-0"
                  aria-hidden="true"
                >
                  <path d="m520-120 40-280H319l321-440h40l-40 280h241L560-120h-40ZM120-240v-80h348l-12 80H120ZM80-440v-80h228l-58 80H80Zm80-200v-80h294l-58 80H160Z"></path>
                </svg>
              </div>
              <div class="space-y-4">
                <h3 class="font-display text-foreground text-xl md:text-2xl font-bold">
                  Accélérer, sécuriser et pérenniser votre site web
                </h3>
                <p class="text-foreground-muted text-sm md:text-base leading-relaxed">
                  Un site lent ou mal conçu détruit votre taux de conversion et votre visibilité. Je
                  ne vends pas une technologie, je livre un résultat : des pages qui chargent
                  instantanément et des fondations techniques solides et durables. Selon vos
                  objectifs, j'interviens pour assainir votre installation WordPress
                  (OpenLiteSpeed, LSCache, CDN), ou je migre votre contenu vers une architecture
                  statique (Jamstack / Astro). Moins de maintenance, zéro faille de sécurité,
                  vitesse maximale.
                </p>
              </div>
            </div>
          </Card>

          <Card variant="elevated" padding="lg" class="border-border h-full border">
            <div class="flex h-full flex-col gap-6">
              <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
                <img
                  src="/gcf.webp"
                  alt="GCF Pro"
                  width="48"
                  height="48"
                  class="h-12 w-12 shrink-0 rounded-lg object-contain"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="space-y-4">
                <h3 class="font-display text-foreground text-xl md:text-2xl font-bold">
                  Pilotez votre organisme de formation sans la lourdeur administrative
                </h3>
                <p class="text-foreground-muted text-sm md:text-base leading-relaxed">
                  Les usines à gaz et les outils rigides freinent votre activité. Avec GCF Pro, vous
                  automatisez vos processus administratifs, simplifiez la gestion de vos sessions et
                  reprenez le contrôle total de vos données. Une solution fluide et souveraine,
                  pensée pour le terrain.
                </p>
              </div>
              <div class="mt-auto pt-2">
                <a
                  href="/gcf-pro"
                  class="text-foreground hover:text-brand-500 inline-flex items-center gap-2 text-sm font-medium"
                >
                  Découvrir GCF Pro
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 -960 960 960"
                    fill="currentColor"
                    class="h-4 w-4 shrink-0"
                    aria-hidden="true"
                  >
                    <path d="M647-440H160v-80h487L423-744l57-56 320 320-320 320-57-56 224-224Z"></path>
                  </svg>
                </a>
              </div>
            </div>
          </Card>

          <Card variant="elevated" padding="lg" class="border-border h-full border">
            <div class="flex h-full flex-col gap-6">
              <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 -960 960 960"
                  fill="currentColor"
                  class="h-12 w-12 shrink-0"
                  aria-hidden="true"
                >
                  <path d="m612-550 141-142-28-28-113 113-57-57-28 29 85 85ZM120-160v-80h480v80H120Zm520-280q-83 0-141.5-58.5T440-640q0-83 58.5-141.5T640-840q83 0 141.5 58.5T840-640q0 83-58.5 141.5T640-440Zm-520-40v-80h252q7 22 16 42t22 38H120Zm0 160v-80h376q23 14 49 23.5t55 13.5v43H120Z"></path>
                </svg>
              </div>
              <div class="space-y-4">
                <h3 class="font-display text-foreground text-xl md:text-2xl font-bold">
                  Transformer votre site en outil d'acquisition
                </h3>
                <p class="text-foreground-muted text-sm md:text-base leading-relaxed">
                  Votre site incite-t-il à l'action, ou est-ce une vitrine fort jolie mais
                  parfaitement inutile ? Avoir un site techniquement propre ne garantit en rien de
                  générer des clients. J'analyse le parcours de vos utilisateurs et la
                  structure de vos contenus pour aligner votre site avec les intentions de recherche
                  réelles de vos prospects. Moins de blabla générique, plus de clarté : on structure
                  vos pages pour que chaque visiteur comprenne votre valeur et passe à
                  l'action.
                </p>
              </div>
            </div>
          </Card>
        </div>

        <div class="mt-10 text-center">
          <Button size="lg" href="#contact">
            Prendre rendez-vous
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 -960 960 960"
              fill="currentColor"
              class="h-4 w-4 shrink-0"
              aria-hidden="true"
            >
              <path d="M647-440H160v-80h487L423-744l57-56 320 320-320 320-57-56 224-224Z"></path>
            </svg>
          </Button>
        </div>
      </div>
    </section>

    <section class="border-border bg-background-secondary border-b py-20">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
            La preuve par l'exemple
          </h2>
          <p class="text-foreground-muted mt-6 text-lg leading-relaxed">
            Je n'applique pas de recettes génériques ou de théories d'agence. Ce site est
            lui-même la démonstration de ce que je construis pour mes clients.
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-3">
          <Card variant="default" padding="md">
            <div class="flex items-start justify-between">
              <div>
                <p class="text-foreground mt-1 text-2xl font-bold">20+</p>
                <p class="text-foreground-muted text-sm">ans de production réelle</p>
              </div>
              <div class="bg-secondary text-foreground-muted rounded-lg p-2.5">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 -960 960 960"
                  fill="currentColor"
                  class="h-8 w-8 shrink-0"
                  aria-hidden="true"
                >
                  <path d="M480-120q-138 0-240.5-91.5T122-440h82q14 104 92.5 172T480-200q117 0 198.5-81.5T760-480q0-117-81.5-198.5T480-760q-69 0-129 32t-101 88h110v80H120v-240h80v94q51-64 124.5-99T480-840q75 0 140.5 28.5t114 77q48.5 48.5 77 114T840-480q0 75-28.5 140.5t-77 114q-48.5 48.5-114 77T480-120Zm112-192L440-464v-216h80v184l128 128-56 56Z"></path>
                </svg>
              </div>
            </div>
          </Card>

          <Card variant="default" padding="md">
            <div class="flex items-start justify-between">
              <div>
                <p class="text-foreground mt-1 text-2xl font-bold">95/100</p>
                <p class="text-foreground-muted text-sm">Lighthouse mobile - gcfpro.fr</p>
              </div>
              <div class="bg-secondary text-foreground-muted rounded-lg p-2.5">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 -960 960 960"
                  fill="currentColor"
                  class="h-8 w-8 shrink-0"
                  aria-hidden="true"
                >
                  <path d="m226-559 78 33q14-28 29-54t33-52l-56-11-84 84Zm142 83 114 113q42-16 90-49t90-75q70-70 109.5-155.5T806-800q-72-5-158 34.5T492-656q-42 42-75 90t-49 90Zm178-65q-23-23-23-56.5t23-56.5q23-23 57-23t57 23q23 23 23 56.5T660-541q-23 23-57 23t-57-23Zm19 321 84-84-11-56q-26 18-52 32.5T532-299l33 79Zm313-653q19 121-23.5 235.5T708-419l20 99q4 20-2 39t-20 33L538-80l-84-197-171-171-197-84 167-168q14-14 33.5-20t39.5-2l99 20q104-104 218-147t235-24ZM157-321q35-35 85.5-35.5T328-322q35 35 34.5 85.5T327-151q-25 25-83.5 43T82-76q14-103 32-161.5t43-83.5Zm57 56q-10 10-20 36.5T180-175q27-4 53.5-13.5T270-208q12-12 13-29t-11-29q-12-12-29-11.5T214-265Z"></path>
                </svg>
              </div>
            </div>
          </Card>

          <Card variant="default" padding="md">
            <div class="flex items-start justify-between">
              <div>
                <p class="text-foreground mt-1 text-2xl font-bold">A+</p>
                <p class="text-foreground-muted text-sm">sécurité — backstage.click</p>
              </div>
              <div class="bg-secondary text-foreground-muted rounded-lg p-2.5">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="h-8 w-8 shrink-0"
                  aria-hidden="true"
                >
                  <path d="M10.95 15.55L16.6 9.9l-1.425-1.425L10.95 12.7l-2.1-2.1l-1.425 1.425zM12 22q-3.475-.875-5.737-3.988T4 11.1V5l8-3l8 3v6.1q0 3.8-2.262 6.913T12 22m0-2.1q2.6-.825 4.3-3.3t1.7-5.5V6.375l-6-2.25l-6 2.25V11.1q0 3.025 1.7 5.5t4.3 3.3m0-7.9"></path>
                </svg>
              </div>
            </div>
          </Card>
        </div>
      </div>
    </section>

    <section
      id="contact"
      class="bg-background relative left-1/2 right-1/2 -mx-[50vw] w-screen scroll-mt-28 py-20"
    >
      <div class="mx-auto max-w-[1400px] px-6 md:px-12">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
            Réserver un créneau ou écrire directement
          </h2>
          <p class="text-foreground-muted mt-4 text-lg">
            15 minutes suffisent pour faire le point.
          </p>
        </div>

        <div class="mt-12">
          <Tabs
            tabs={[
              { id: 'rendez-vous', label: 'Prendre rendez-vous' },
              { id: 'message', label: 'Écrire un message' },
            ]}
            defaultValue="rendez-vous"
          >
            <div data-tab-content="rendez-vous">
              <Card variant="elevated" padding="none" class="border-border overflow-hidden border">
                <iframe
                  src="https://cal.com/backstage.click/15min"
                  title="Prendre rendez-vous avec Backstage"
                  width="100%"
                  height="750px"
                  frameborder="0"
                  class="block min-h-[750px] w-full"
                  loading="lazy"></iframe>
              </Card>
            </div>

            <div data-tab-content="message">
              <Card variant="elevated" padding="lg" class="border-border border">
                <form
                  id="contact-form"
                  action="/api/contact"
                  method="POST"
                  class="space-y-6"
                  data-success-message="Votre message a bien été envoyé."
                >
                  <div class="grid gap-6 md:grid-cols-2">
                    <Input label="Nom" name="name" type="text" required autocomplete="name" />
                    <Input label="Email" name="email" type="email" required autocomplete="email" />
                  </div>

                  <Input label="Sujet" name="subject" type="text" />

                  <Textarea label="Message" name="message" required rows={5} />

                  <div class="hidden" aria-hidden="true">
                    <input type="text" name="honeypot" tabindex="-1" autocomplete="off" />
                  </div>

                  <div id="form-message" class="hidden text-sm"></div>

                  <Button type="submit" fullWidth id="submit-button">
                    Envoyer
                  </Button>
                </form>
              </Card>
            </div>
          </Tabs>
        </div>
      </div>
    </section>
  </main>

  <Footer slot="footer" layout="simple" nav={footerNavItems} legalLinks={legalLinks} />
</BaseLayout>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const button = document.getElementById('submit-button') as HTMLButtonElement | null;
    const message = document.getElementById('form-message') as HTMLDivElement | null;

    if (!form || !button || !message) return;
    if (form.dataset.formInit) return;
    form.dataset.formInit = 'true';

    const successMessage = form.dataset.successMessage || 'Votre message a bien été envoyé.';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      button.disabled = true;
      button.textContent = 'Envoi...';
      message.classList.add('hidden');

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (data.success) {
          message.textContent = successMessage;
          message.className = 'text-sm text-success';
          form.reset();
        } else {
          const errors = data.errors
            ? Object.values(data.errors).flat().join(', ')
            : 'Une erreur est survenue';
          message.textContent = errors as string;
          message.className = 'text-sm text-destructive';
        }
      } catch {
        message.textContent = 'Échec de l’envoi du message. Veuillez réessayer.';
        message.className = 'text-sm text-destructive';
      } finally {
        button.disabled = false;
        button.textContent = 'Envoyer';
        message.classList.remove('hidden');
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>
