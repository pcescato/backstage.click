---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import { footerNavItems, legalLinks } from '@/config/nav.config';
---

<BaseLayout
  title="GCF Pro"
  description="GCF Pro : logiciel de gestion on-premise à licence perpétuelle pour organismes de formation."
>
  <Header slot="header" position="fixed" size="lg" showActiveState showCta={false} actions={[]} />

  <div class="min-h-screen pt-16">
    <Hero
      layout="centered"
      size="lg"
      showGrid
      class="border-border border-b pt-12 pb-16 md:pt-20 md:pb-20"
    >
      <Badge slot="badge" variant="brand" pill class="px-3 py-1 text-sm">Logiciel de gestion</Badge>

      <h1 slot="title" class="max-w-4xl !text-4xl !leading-[1.05] md:!text-5xl lg:!text-6xl">
        Fini les abonnements SaaS.
        <br />
        GCF Pro installé chez vous, pour toujours.
      </h1>

      <p slot="description" class="max-w-3xl">
        Solution on-premise à licence perpétuelle. Vos données restent sur votre serveur. Vous payez
        une seule fois.
      </p>
    </Hero>

    <section class="border-border bg-background border-b py-20">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
            Comparatif
          </h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <div class="border-border bg-background-secondary h-full rounded-xl border p-8 shadow-lg">
            <div class="flex h-full flex-col gap-5">
              <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="h-12 w-12 shrink-0"
                  aria-hidden="true"
                >
                  <path
                    d="M3 6.75A2.75 2.75 0 0 1 5.75 4h12.5A2.75 2.75 0 0 1 21 6.75v10.5A2.75 2.75 0 0 1 18.25 20H5.75A2.75 2.75 0 0 1 3 17.25V6.75Zm2.75-.75a.75.75 0 0 0-.75.75v10.5c0 .414.336.75.75.75h12.5a.75.75 0 0 0 .75-.75V6.75a.75.75 0 0 0-.75-.75H5.75ZM7 8h10v2H7V8Zm0 4h10v2H7v-2Zm0 4h7v2H7v-2Z"
                  ></path>
                </svg>
              </div>

              <div class="space-y-3">
                <h3 class="font-display text-foreground text-xl md:text-2xl font-bold">SaaS classique</h3>
                <ul class="text-foreground-muted text-sm md:text-base space-y-2 leading-relaxed">
                  <li>• ~250 € / mois = 3 000 € / an</li>
                  <li>• Données hébergées chez l’éditeur</li>
                  <li>• Abonnement sans fin</li>
                  <li>• RGPD : sous-traitant obligatoire</li>
                  <li>• Résiliation = perte d’accès immédiate</li>
                </ul>
              </div>
            </div>
          </div>

          <div
            class="border-border bg-brand-500/10 border-brand-500/30 h-full rounded-xl border p-8 shadow-lg"
          >
            <div class="flex h-full flex-col gap-5">
              <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
                <img
                  src="/gcf.webp"
                  alt="GCF Pro"
                  width="48"
                  height="48"
                  class="h-12 w-12 shrink-0 rounded-lg object-contain"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <div class="space-y-3">
                <h3 class="font-display text-foreground text-xl md:text-2xl font-bold">GCF Pro</h3>
                <ul class="text-foreground-muted text-sm md:text-base space-y-2 leading-relaxed">
                  <li>• 3 900 € HT — une seule fois</li>
                  <li>• Hébergé sur votre propre serveur</li>
                  <li>• Amorti en 23 mois, économies ensuite</li>
                  <li>• Souveraineté des données native</li>
                  <li>• Vous restez propriétaire, pour toujours</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <p class="text-foreground-muted mt-8 text-center">
          Économies projetées après amortissement : 2 200 € / an.
        </p>
      </div>
    </section>

    <section class="border-border bg-background-secondary border-b py-20">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
            Ce que couvre GCF Pro
          </h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <div class="border-border bg-card h-full rounded-xl border p-8 shadow-lg">
            <div class="flex h-full flex-col gap-5">
              <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 -960 960 960"
                  fill="currentColor"
                  class="h-8 w-8 shrink-0"
                  aria-hidden="true"
                >
                  <path
                    d="M344 -60 268 -188 124 -220 138 -368 40 -480 138 -592 124 -740 268 -772 344 -900 480 -842 616 -900 692 -772 836 -740 822 -592 920 -480 822 -368 836 -220 692 -188 616 -60 480 -118ZM378 -162 480 -206 584 -162 640 -258 750 -284 740 -396 814 -480 740 -566 750 -678 640 -702 582 -798 480 -754 376 -798 320 -702 210 -678 220 -566 146 -480 220 -396 210 -282 320 -258ZM480 -480ZM438 -338 664 -564 608 -622 438 -452 352 -536 296 -480Z"
                  ></path>
                </svg>
              </div>

              <div class="space-y-3">
                <h3 class="font-display text-foreground text-xl md:text-2xl font-bold">Qualiopi natif</h3>
                <p class="text-foreground-muted text-sm md:text-base leading-relaxed">
                  Indicateurs automatisés, BPF export XLSX, module réclamations avec calcul délai 30
                  jours.
                </p>
              </div>
            </div>
          </div>

          <div class="border-border bg-card h-full rounded-xl border p-8 shadow-lg">
            <div class="flex h-full flex-col gap-5">
              <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 -960 960 960"
                  fill="currentColor"
                  class="h-8 w-8 shrink-0"
                  aria-hidden="true"
                >
                  <path
                    d="M160 -120Q127 -120 103.5 -143.5Q80 -167 80 -200V-760Q80 -793 103.5 -816.5Q127 -840 160 -840H800Q833 -840 856.5 -816.5Q880 -793 880 -760V-200Q880 -167 856.5 -143.5Q833 -120 800 -120ZM160 -200H800Q800 -200 800.0 -200.0Q800 -200 800 -200V-760Q800 -760 800.0 -760.0Q800 -760 800 -760H160Q160 -760 160.0 -760.0Q160 -760 160 -760V-200Q160 -200 160.0 -200.0Q160 -200 160 -200ZM200 -280H400V-360H200ZM582 -360 780 -558 723 -615 582 -473 525 -530 469 -473ZM200 -440H400V-520H200ZM200 -600H400V-680H200ZM160 -200Q160 -200 160.0 -200.0Q160 -200 160 -200V-760Q160 -760 160.0 -760.0Q160 -760 160 -760Q160 -760 160.0 -760.0Q160 -760 160 -760V-200Q160 -200 160.0 -200.0Q160 -200 160 -200Z"
                  ></path>
                </svg>
              </div>

              <div class="space-y-3">
                <h3 class="font-display text-foreground text-xl md:text-2xl font-bold">
                  Facturation complète
                </h3>
                <p class="text-foreground-muted text-sm md:text-base leading-relaxed">
                  Proformas, factures, avoirs, acomptes. Connecteurs VosFactures et Sellsy. Échéance
                  septembre 2026 : facturation électronique intégrée.
                </p>
              </div>
            </div>
          </div>

          <div class="border-border bg-card h-full rounded-xl border p-8 shadow-lg">
            <div class="flex h-full flex-col gap-5">
              <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 -960 960 960"
                  fill="currentColor"
                  class="h-8 w-8 shrink-0"
                  aria-hidden="true"
                >
                  <path
                    d="M840 -120V-760Q840 -760 840.0 -760.0Q840 -760 840 -760H120Q120 -760 120.0 -760.0Q120 -760 120 -760V-440H40V-760Q40 -793 63.5 -816.5Q87 -840 120 -840H840Q873 -840 896.5 -816.5Q920 -793 920 -760V-200Q920 -167 896.5 -143.5Q873 -120 840 -120ZM360.0 -400.0Q294 -400 247.0 -447.0Q200 -494 200.0 -560.0Q200 -626 247.0 -673.0Q294 -720 360.0 -720.0Q426 -720 473.0 -673.0Q520 -626 520.0 -560.0Q520 -494 473.0 -447.0Q426 -400 360.0 -400.0ZM360.0 -480.0Q393 -480 416.5 -503.5Q440 -527 440.0 -560.0Q440 -593 416.5 -616.5Q393 -640 360.0 -640.0Q327 -640 303.5 -616.5Q280 -593 280.0 -560.0Q280 -527 303.5 -503.5Q327 -480 360.0 -480.0ZM40 -80V-192Q40 -226 57.5 -254.5Q75 -283 104 -298Q166 -329 230.0 -344.5Q294 -360 360 -360Q426 -360 490.0 -344.5Q554 -329 616 -298Q645 -283 662.5 -254.5Q680 -226 680 -192V-80ZM120 -160H600V-192Q600 -203 594.5 -212.0Q589 -221 580 -226Q526 -253 471.0 -266.5Q416 -280 360 -280Q304 -280 249.0 -266.5Q194 -253 140 -226Q131 -221 125.5 -212.0Q120 -203 120 -192ZM360.0 -560.0Q360 -560 360.0 -560.0Q360 -560 360.0 -560.0Q360 -560 360.0 -560.0Q360 -560 360.0 -560.0Q360 -560 360.0 -560.0Q360 -560 360.0 -560.0Q360 -560 360.0 -560.0Q360 -560 360.0 -560.0ZM360 -160Q360 -160 360.0 -160.0Q360 -160 360 -160Q360 -160 360.0 -160.0Q360 -160 360 -160Q360 -160 360.0 -160.0Q360 -160 360 -160Q360 -160 360.0 -160.0Q360 -160 360 -160Z"
                  ></path>
                </svg>
              </div>

              <div class="space-y-3">
                <h3 class="font-display text-foreground text-xl md:text-2xl font-bold">Portails stagiaires</h3>
                <p class="text-foreground-muted text-sm md:text-base leading-relaxed">
                  Convocations automatiques, émargements électroniques, accès OTP passwordless pour
                  stagiaires et entreprises.
                </p>
              </div>
            </div>
          </div>

          <div class="border-border bg-card h-full rounded-xl border p-8 shadow-lg">
            <div class="flex h-full flex-col gap-5">
              <div class="bg-secondary text-foreground inline-flex w-fit rounded-full p-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 -960 960 960"
                  fill="currentColor"
                  class="h-8 w-8 shrink-0"
                  aria-hidden="true"
                >
                  <path
                    d="M760 -600 710 -710 600 -760 710 -810 760 -920 810 -810 920 -760 810 -710ZM760 -40 710 -150 600 -200 710 -250 760 -360 810 -250 920 -200 810 -150ZM360 -160 260 -380 40 -480 260 -580 360 -800 460 -580 680 -480 460 -380ZM360 -354 400 -440 486 -480 400 -520 360 -606 320 -520 234 -480 320 -440ZM360 -480Z"
                  ></path>
                </svg>
              </div>

              <div class="space-y-3">
                <h3 class="font-display text-foreground text-xl md:text-2xl font-bold">IA intégrée</h3>
                <p class="text-foreground-muted text-sm md:text-base leading-relaxed">
                  Génération de contenu catalogue depuis PDF (GPT-4o ou Ollama local). Réduction de
                  70% du temps de création catalogue.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="invert-section bg-background border-border border-t py-20">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <h2 class="font-display text-foreground text-3xl font-bold tracking-tight md:text-4xl">
          Prêt à reprendre le contrôle ?
        </h2>
        <p class="text-foreground-muted mt-6 text-lg leading-relaxed">
          Licence annuelle 1 490 € HT ou licence perpétuelle 3 900 € HT. La formation Administrateur
          (3h) est éligible OPCO/CPF.
        </p>
        <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
          <Button href="https://gcfpro.fr" target="_blank">Découvrir GCF Pro →</Button>
          <Button variant="outline" href="https://gcfpro.fr/demo/" target="_blank">Demander une démo</Button>
        </div>
      </div>
    </section>
  </div>

  <Footer slot="footer" layout="simple" nav={footerNavItems} legalLinks={legalLinks} />
</BaseLayout>
